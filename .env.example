# ── LLM ──────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Vector Store ──────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=temporal-rag
PINECONE_ENVIRONMENT=us-east-1

# ── Database ──────────────────────────────────────────
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/temporalrag

# ── Cache ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── App ───────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO

# ── Temporal Tuning ───────────────────────────────────
DECAY_RATE_POLICY=0.15
DECAY_RATE_RESEARCH=0.03
DECAY_RATE_CHANGELOG=0.20
DECAY_RATE_NEWS=0.25
DECAY_RATE_DEFAULT=0.10

CONFLICT_THRESHOLD_DAYS=90
TOPIC_SIMILARITY_THRESHOLD=0.88
